# This app is deployed as a subfolder of the public web root
# (public_html/hotel_reservation) so Hostinger's Git auto-deploy tool can
# target it. Nothing under this folder should ever be served directly -
# public_html/index.php reaches it only via PHP require, not HTTP. Block
# all direct requests here as defense in depth.
<IfModule mod_authz_core.c>
    Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
</IfModule>
